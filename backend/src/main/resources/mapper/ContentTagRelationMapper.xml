<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.gym.mapper.ContentTagRelationMapper">
    <resultMap id="BaseResultMap" type="com.gym.entity.ContentTagRelation">
        <id column="id" property="id" />
        <result column="content_id" property="contentId" />
        <result column="tag_id" property="tagId" />
    </resultMap>

    <insert id="insert" parameterType="com.gym.entity.ContentTagRelation">
        INSERT INTO content_tag_relation (content_id, tag_id)
        VALUES (#{contentId}, #{tagId})
    </insert>

    <delete id="delete" parameterType="java.lang.Integer">
        DELETE FROM content_tag_relation WHERE id = #{id}
    </delete>

    <delete id="deleteByContentId" parameterType="java.lang.Integer">
        DELETE FROM content_tag_relation WHERE content_id = #{contentId}
    </delete>

    <select id="selectByContentId" parameterType="java.lang.Integer" resultMap="BaseResultMap">
        SELECT * FROM content_tag_relation WHERE content_id = #{contentId}
    </select>

    <select id="selectByTagId" parameterType="java.lang.Integer" resultMap="BaseResultMap">
        SELECT * FROM content_tag_relation WHERE tag_id = #{tagId}
    </select>
</mapper>
